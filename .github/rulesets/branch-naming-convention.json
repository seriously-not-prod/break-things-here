{
  "name": "Branch Naming Convention",
  "target": "branch",
  "enforcement": "active",
  "conditions": {
    "ref_name": {
      "include": [
        "refs/heads/feature/**",
        "refs/heads/bugfix/**",
        "refs/heads/hotfix/**",
        "refs/heads/release/**"
      ],
      "exclude": []
    }
  },
  "rules": [
    {
      "type": "branch_name_pattern",
      "parameters": {
        "operator": "regex",
        "name": "Issue-based branch naming",
        "pattern": "^(feature|bugfix|hotfix|release)\\/[0-9]+-[a-z0-9-]+$"
      }
    }
  ]
}
