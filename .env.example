# ===========================================
# Festival Event Planner - Environment Config
# ===========================================
# Copy this file to .env and update values
# NEVER commit the .env file to version control
# ===========================================

# --- Frontend ---
FRONTEND_PORT=3000

# --- Backend ---
BACKEND_PORT=4000

# --- PostgreSQL Database ---
POSTGRES_PORT=5432
POSTGRES_DB=festival_planner
POSTGRES_USER=festival_user
POSTGRES_PASSWORD=change_me_in_local_env
