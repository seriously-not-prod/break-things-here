# =============================================
# Festival Event Planner — Environment Variables
# Copy this file to .env and fill in the values
# NEVER commit .env to version control
# =============================================

# ---- Ports ----
FRONTEND_PORT=3000
BACKEND_PORT=4000
DB_PORT=5432

# ---- Server ----
NODE_ENV=development

# ---- Database ----
# PostgreSQL connection string for local development.
# Local:  postgresql://postgres:<password>@localhost:5432/festival_planner
# Docker Compose sets a container-specific DATABASE_URL for the backend service.
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/festival_planner
POSTGRES_PASSWORD=postgres

# ---- JWT Authentication ----
# Generate with: node -e "console.log(require('crypto').randomBytes(64).toString('hex'))"
JWT_SECRET=change-this-to-a-long-random-secret
JWT_EXPIRES_IN=7d
SESSION_TIMEOUT_MS=1800000

# ---- Token Hashing (scrypt KDF salt) ----
# Used to hash session tokens before DB storage. Must be set in production.
# Generate with: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
TOKEN_HASH_SECRET=change-this-to-a-random-secret

# ---- Refresh Token Encryption ----
# AES-256 key encoded as base64 (32 raw bytes → 44 base64 chars).
# Generate with: node -e "console.log(require('crypto').randomBytes(32).toString('base64'))"
REFRESH_TOKEN_ENC_KEY=base64-encoded-32-byte-key-here

# ---- CORS ----
# Comma-separated list of allowed origins in production
CORS_ALLOWED_ORIGINS=http://localhost:3000,http://localhost:5173

# ---- Email (SMTP) ----
# For Gmail: enable 2FA and create an App Password at
#   https://myaccount.google.com/apppasswords
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=your-email@gmail.com
SMTP_PASS=your-app-password
SMTP_FROM=Festival Planner <your-email@gmail.com>

# ---- Azure Entra ID (Microsoft Identity) ----
# Set ENTRA_AUTH_ENABLED=true to enable sign-in with Microsoft alongside local auth.
# Register an app in Azure Portal → App registrations to obtain the values below.
ENTRA_AUTH_ENABLED=false
AZURE_TENANT_ID=your-tenant-id
AZURE_CLIENT_ID=your-client-id
AZURE_CLIENT_SECRET=your-client-secret
# Redirect URI must match the one registered in Azure App Registration
AZURE_REDIRECT_URI=http://localhost:3000/auth/entra/callback

# ---- AI Suggestions (OpenAI) ----
# Get your API key at https://platform.openai.com/api-keys
OPENAI_API_KEY=sk-...

# ---- Frontend (Vite) ----
# Prefix ALL frontend-visible env vars with VITE_
# Leave VITE_API_URL empty when running via Docker (nginx proxies /api to the backend)
VITE_API_URL=http://localhost:4000
# Session inactivity timeout in milliseconds shown to the user (default 30 min)
VITE_SESSION_TIMEOUT_MS=1800000
