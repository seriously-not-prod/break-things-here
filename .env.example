# =============================================
# Festival Event Planner — Environment Variables
# Copy this file to .env and fill in the values
# NEVER commit .env to version control
# =============================================

# ---- Ports ----
FRONTEND_PORT=3000
BACKEND_PORT=4000
DB_PORT=5432

# ---- Server ----
NODE_ENV=development

# ---- Database ----
# PostgreSQL connection string for local development.
# Local:  postgresql://postgres:<password>@localhost:5432/festival_planner
# Docker Compose sets a container-specific DATABASE_URL for the backend service.
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/festival_planner
POSTGRES_PASSWORD=postgres

# ---- JWT Authentication ----
# Generate with: node -e "console.log(require('crypto').randomBytes(64).toString('hex'))"
JWT_SECRET=change-this-to-a-long-random-secret
JWT_EXPIRES_IN=7d
SESSION_TIMEOUT_MS=1800000

# ---- Token Hashing (scrypt KDF salt) ----
# Used to hash session tokens before DB storage. Must be set in production.
# Generate with: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
TOKEN_HASH_SECRET=change-this-to-a-random-secret

# ---- Refresh Token Encryption ----
# AES-256 key encoded as base64 (32 raw bytes → 44 base64 chars).
# Generate with: node -e "console.log(require('crypto').randomBytes(32).toString('base64'))"
REFRESH_TOKEN_ENC_KEY=base64-encoded-32-byte-key-here

# ---- CORS ----
# Comma-separated list of allowed origins in production
CORS_ALLOWED_ORIGINS=http://localhost:3000,http://localhost:5173

# ---- Email (SMTP) ----
# For Gmail: enable 2FA and create an App Password at
#   https://myaccount.google.com/apppasswords
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=your-email@gmail.com
SMTP_PASS=your-app-password
SMTP_FROM=Festival Planner <your-email@gmail.com>

# ---- Inbound Email Webhook (HMAC) ----
# Shared secret used to verify the HMAC-SHA256 signature on
# POST /webhooks/email/bounce (#709). The email provider (SES/Mailgun/etc.)
# signs the raw body with this secret; the middleware compares with
# constant-time equality. If unset, the endpoint rejects every request with
# 401 "not configured" — set it before enabling bounce processing.
# Generate with: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
EMAIL_WEBHOOK_SECRET=

# ---- Azure Entra ID (Microsoft Identity) ----
# Azure Entra ID is the PRIMARY authentication method (FR-AUTH-001).
# Register an app in Azure Portal → App registrations to obtain the values below.
# REQUIRED: Set AZURE_TENANT_ID, AZURE_CLIENT_ID, AZURE_CLIENT_SECRET before deploying.
ENTRA_AUTH_ENABLED=true
ENTRA_MFA_REQUIRED=true
# #781 — When Entra is enabled, the login page hides the email/password form
# by default. Set this to `true` to expose a "Use a local account" disclosure
# that reveals the legacy credential fields. Production deployments should
# leave this `false` so SSO cannot be silently bypassed.
ENTRA_ALLOW_LOCAL_FALLBACK=false
AZURE_TENANT_ID=your-tenant-id
AZURE_CLIENT_ID=your-client-id
AZURE_CLIENT_SECRET=your-client-secret
# Redirect URI must match the one registered in Azure App Registration
AZURE_REDIRECT_URI=http://localhost:8081/auth/callback
# For CIAM tenants, set the full authority URL (ciamlogin.com).
# Leave unset for standard AAD tenants (uses login.microsoftonline.com by default).
# AZURE_AUTHORITY=https://your-subdomain.ciamlogin.com/your-tenant-id
# Azure group object IDs used to map users to app roles
ENTRA_GROUP_ADMINS=00000000-0000-0000-0000-000000000000
ENTRA_GROUP_ORGANIZERS=00000000-0000-0000-0000-000000000000
ENTRA_GROUP_COLLABORATORS=00000000-0000-0000-0000-000000000000
ENTRA_GROUP_GUESTS=00000000-0000-0000-0000-000000000000
ENTRA_GROUP_VIEWERS=00000000-0000-0000-0000-000000000000

# ---- AI Suggestions (OpenAI) ----
# Get your API key at https://platform.openai.com/api-keys
OPENAI_API_KEY=sk-...

# ---- Frontend (Vite) ----
# Prefix ALL frontend-visible env vars with VITE_
# Leave VITE_API_URL empty when running via Docker (nginx proxies /api to the backend)
VITE_API_URL=http://localhost:4000
# Session inactivity timeout in milliseconds shown to the user (default 30 min)
VITE_SESSION_TIMEOUT_MS=1800000

# ---- Job Scheduler (#676) ----
# GDPR: number of days after soft-delete before personal data is anonymised
DATA_RETENTION_DAYS=90

# ---- Virus Scanning (#672) ----
# Set to 'true' to use real ClamAV (clamscan binary must be installed)
VIRUS_SCAN_ENABLED=false
# Set to 'true' to reject uploads when scanner is unavailable (fail-closed)
VIRUS_SCAN_BLOCK_ON_ERROR=false

# ---- GDPR (#680) ----
# Maximum days to retain soft-deleted user personal data before purging
DATA_RETENTION_DAYS=90

# ---- AI Integration (#674) ----
# OpenAI API key for AI suggestions. Leave blank to use graceful fallback.
OPENAI_API_KEY=

# ---- Structured Logging (#676) ----
# Set to 'production' or 'staging' to enable JSON structured logging
# NODE_ENV=production

# ---- CORS (#676) ----
# Comma-separated list of allowed frontend origins in production
# CORS_ALLOWED_ORIGINS=https://yourapp.example.com
