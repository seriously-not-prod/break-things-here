# =============================================
# Festival Event Planner — Environment Variables
# Copy this file to .env and fill in the values
# NEVER commit .env to version control
# =============================================

# ---- Ports ----
FRONTEND_PORT=3000
BACKEND_PORT=4000

# ---- Server ----
NODE_ENV=development

# ---- Database (SQLite — no external DB needed) ----
# Path to the SQLite file. Use :memory: for automated tests.
DATABASE_URL=./database/dev.sqlite

# ---- JWT Authentication ----
# Generate a secure secret:
#   node -e "console.log(require('crypto').randomBytes(64).toString('hex'))"
JWT_SECRET=change-this-to-a-long-random-secret
JWT_EXPIRES_IN=7d
SESSION_TIMEOUT_MS=1800000

# ---- CORS ----
# Comma-separated list of allowed origins in production
CORS_ALLOWED_ORIGINS=http://localhost:3000,http://localhost:5173

# ---- Email (SMTP) ----
# For Gmail: enable 2FA and create an App Password at
#   https://myaccount.google.com/apppasswords
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=your-email@gmail.com
SMTP_PASS=your-app-password
SMTP_FROM=Festival Planner <your-email@gmail.com>

# ---- AI Suggestions (OpenAI) ----
# Get your API key at https://platform.openai.com/api-keys
OPENAI_API_KEY=sk-...

# ---- Frontend (Vite) ----
# Prefix ALL frontend-visible env vars with VITE_
VITE_API_URL=http://localhost:4000
